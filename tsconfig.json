{
  "include": ["src"],
  "compilerOptions": {
   "lib": ["DOM", "DOM.Iterable", "ES2022"],
   "types": ["node"],
   "isolatedModules": true,
   "esModuleInterop": true,
   "module": "ESNext",
   "moduleResolution": "Bundler",
   "resolveJsonModule": true,
   "target": "ES2022",
   "strict": true,
   "allowJs": false,
   "skipLibCheck": true,
   "forceConsistentCasingInFileNames": true,
   "declaration": true,
   "declarationMap": false,
   "rootDir": "src",
   "outDir": "dist",
   "noEmit": false
  }
}
